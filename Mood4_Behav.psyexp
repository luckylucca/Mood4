    <Routine name="instructions7"/>
    <Routine name="instructions8"/>
    <Routine name="happy_overall"/>
    <Routine name="instructions10"/>
    <Routine name="happy_base"/>
    <Routine name="instructions10_2"/>
    <Routine name="instructions11"/>

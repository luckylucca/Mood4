        <Param val="p_progVal = 1" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="p_progVal = 1;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="p_progBar = (p_progVal / (npractice_trials/3));&amp;#10;p_progVal += 1;&amp;#10;psychoJS.eventManager.clearEvents();&amp;#10;&amp;#10;if ((p_userchoice === &quot;left&quot;)) {&amp;#10;    if ((p_gambles[practice_trials.thisN][0] &gt;= p_gamble_result[practice_trials.thisN])) {&amp;#10;        p_current_money += p_gambles[practice_trials.thisN][1];&amp;#10;        outcome_txtW = &quot;Win!&quot;;&amp;#10;        W_pos = 0.03;&amp;#10;        outcome_rewa = p_gambles_txt[practice_trials.thisN][1];&amp;#10;        outcome_rewaL_txt = p_gambles_txt[practice_trials.thisN][2];&amp;#10;        rewa_pos = (- 0.03);&amp;#10;        outcome_color = &quot;Green&quot;;&amp;#10;        outcome = 1;&amp;#10;    } else {&amp;#10;        outcome_txtW = &quot;Loss!&quot;;&amp;#10;        W_pos = 0;&amp;#10;        outcome_rewa = &quot;&quot;;&amp;#10;        outcome_rewaL_txt = &quot;&quot;;&amp;#10;        rewa_pos = (- 1.5);&amp;#10;        outcome_color = &quot;Red&quot;;&amp;#10;        outcome = 0;&amp;#10;    }&amp;#10;} else {&amp;#10;    if ((p_gambles[practice_trials.thisN][2] &gt;= p_gamble_result[practice_trials.thisN])) {&amp;#10;        p_current_money += p_gambles[practice_trials.thisN][3];&amp;#10;        outcome_txtW = &quot;Win!&quot;;&amp;#10;        W_pos = 0.03;&amp;#10;        outcome_rewa = p_gambles_txt[practice_trials.thisN][4];&amp;#10;        outcome_rewaL_txt = p_gambles_txt[practice_trials.thisN][5];&amp;#10;        rewa_pos = (- 0.03);&amp;#10;        outcome_color = &quot;Green&quot;;&amp;#10;        outcome = 1;&amp;#10;    } else {&amp;#10;        outcome_txtW = &quot;Loss!&quot;;&amp;#10;        W_pos = 0;&amp;#10;        outcome_rewa = &quot;&quot;;&amp;#10;        outcome_rewaL_txt = &quot;&quot;;&amp;#10;        rewa_pos = (- 1.5);&amp;#10;        outcome_color = &quot;Red&quot;;&amp;#10;        outcome = 0;&amp;#10;    }&amp;#10;}&amp;#10;&amp;#10;psychoJS.experiment.addData(&quot;current_money_prac&quot;, p_current_money);&amp;#10;let p_money_txt = `$${p_current_money.toFixed(2)}`;&amp;#10;psychoJS.experiment.addData(&quot;outcome_prac&quot;, outcome);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="p_progBar = p_progVal/npractice_trials&amp;#10;p_progVal += 1&amp;#10;&amp;#10;event.clearEvents()&amp;#10;&amp;#10;thisExp.addData('current_money_prac', current_money)&amp;#10;&amp;#10;added_money = 0&amp;#10;&amp;#10;if p_userchoice == 'left':&amp;#10;    if not(forced_trial): # choice trial&amp;#10;        if sure_left: # sure option choosen&amp;#10;            outcome_txtW = 'Win!'&amp;#10;            added_money = options_prac[practice_trials.thisN][0]&amp;#10;            outcome = -1&amp;#10;        else: # gamble choosen&amp;#10;            if options_prac[practice_trials.thisN][3] &gt;= gamble_result_prac[practice_trials.thisN]: # gamble win&amp;#10;                outcome_txtW = 'Win!'&amp;#10;                added_money = options_prac[practice_trials.thisN][2]&amp;#10;                outcome = 1&amp;#10;            else: # gamble loose&amp;#10;                outcome_txtW = 'Loss!'&amp;#10;                outcome = 0&amp;#10;else: # User chose right&amp;#10;    if not(forced_trial): # choice trial&amp;#10;        if not(sure_left): # sure option choosen&amp;#10;            outcome_txtW = 'Win!'&amp;#10;            added_money = options_prac[practice_trials.thisN][4]&amp;#10;            outcome = -1&amp;#10;        else: # gamble choosen&amp;#10;            if options_prac[practice_trials.thisN][5] &gt;= gamble_result_prac[practice_trials.thisN]: # gamble win&amp;#10;                outcome_txtW = 'Win!'&amp;#10;                added_money = options_prac[practice_trials.thisN][4]&amp;#10;                outcome = 1&amp;#10;            else: # gamble loose&amp;#10;                outcome_txtW = 'Loss!'&amp;#10;                outcome = 0&amp;#10;&amp;#10;if forced_trial: # forced choice&amp;#10;    if forced_type_sure: # forced sure option&amp;#10;        outcome_txtW = 'Win!'&amp;#10;        outcome = -1&amp;#10;        if trial_side_left: # left side option&amp;#10;            added_money = options_prac[practice_trials.thisN][0]&amp;#10;        else: # right side option&amp;#10;            added_money = options_prac[practice_trials.thisN][4]&amp;#10;    else: # forced gamble&amp;#10;        if trial_side_left:&amp;#10;            if options_prac[practice_trials.thisN][3]&gt;=gamble_result_prac[practice_trials.thisN]: # gamble win&amp;#10;                outcome_txtW = 'Win!'&amp;#10;                added_money = options_prac[practice_trials.thisN][2]&amp;#10;                outcome = 1&amp;#10;            else: # gamble loose&amp;#10;                outcome_txtW = 'Loss!'&amp;#10;                outcome = 0&amp;#10;&amp;#10;if outcome == -1 or outcome == 1:&amp;#10;    outcome_color = 'green'&amp;#10;else:&amp;#10;    outcome_color = 'red'&amp;#10;&amp;#10;current_money += added_money&amp;#10;&amp;#10;#p_money_txt = f&quot;$ {current_money:.2f}&quot;&amp;#10;#&amp;#10;thisExp.addData(&quot;outcome_prac&quot;, outcome)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="p_gamble_result_code" valType="code" updates="None" name="name"/>
      </CodeComponent>

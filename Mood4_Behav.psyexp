        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="responses = event.getKeys()&amp;#10;if happiness_rating.getRating() != None and len(responses)&gt;0 and responses[-1] == &quot;return&quot; :&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
